# =============================================================================
# Forge — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Forge
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Base directory for all application data (datasets, outputs, models)
FORGE_DATA_DIR=./data

# ---------------------------------------------------------------------------
# HuggingFace (optional, for future ML work)
# ---------------------------------------------------------------------------
# HF_HOME=~/.cache/huggingface
# HF_TOKEN=
